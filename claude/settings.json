{
  "permissions": {
    "defaultMode": "default",
    "additionalDirectories": [
      "~/git-repos"
    ],
    "allow": [
      "Read(~/git-repos/**)",
      "Edit(~/git-repos/**)",
      "Write(~/git-repos/**)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm ci)",
      "Bash(yarn:*)",
      "Bash(pnpm:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(Rscript:*)",
      "Bash(R CMD:*)",
      "Bash(make:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr status:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh release view:*)",
      "Bash(gh release list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh auth status:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)"
    ],
    "ask": [
      "Bash(npm publish:*)",
      "Bash(git merge:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git rebase:*)",
      "Bash(git restore:*)",
      "Bash(git stash drop:*)",
      "Bash(git stash clear:*)",
      "Bash(gh pr checkout:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr review:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh run rerun:*)",
      "Bash(gh workflow run:*)"
    ],
    "deny": [
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue close:*)",
      "Bash(gh release create:*)",
      "Bash(gh release delete:*)",
      "Bash(gh repo create:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh secret set:*)",
      "Bash(gh secret delete:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(mv:*)",
      "Bash(shred:*)",
      "Bash(dd:*)",
      "Bash(sudo:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*credentials*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)"
    ]
  },
  "hooks": { "PreToolUse": [ { "matcher": "Bash", "hooks": [ { "type": "command", "command": "jq -r '.tool_input.command // \"\"' | grep -Eq '(^|[^[:alnum:]_])cd |;|&&|\\|\\|' && jq -n '{hookSpecificOutput:{hookEventName:\"PreToolUse\",permissionDecision:\"deny\",permissionDecisionReason:\"Blocked by local hook: avoid cd and command chaining (; && ||). Use a single simple command with an absolute path or git -C.\"}}' || true" }, { "type": "command", "command": "jq -r '.tool_input.command // \"\"' | grep -Eq '(^|[^[:alnum:]_])git[[:space:]]+([^[:space:]]+[[:space:]]+)*(commit|push)([[:space:]]|$)' && jq -n '{hookSpecificOutput:{hookEventName:\"PreToolUse\",permissionDecision:\"deny\",permissionDecisionReason:\"Blocked by local hook: git commit/push is prohibited here. Ask the user to run it themselves.\"}}' || true" }, { "type": "command", "command": "jq -e 'select(.tool_input.dangerouslyDisableSandbox == true) | select(((.tool_input.command // \"\") | test(\"gradlew|start_servers|remote_\")) | not)' >/dev/null 2>&1 && jq -n '{hookSpecificOutput:{hookEventName:\"PreToolUse\",permissionDecision:\"deny\",permissionDecisionReason:\"Unsandboxed Bash is restricted to the Armadillo launch (gradlew/start_servers). Run other commands sandboxed.\"}}' || true" } ] }, { "matcher": "Write|Edit", "hooks": [ { "type": "command", "command": "jq -e 'select(.tool_input.file_path // \"\" | test(\"/[.]claude/(CLAUDE[.]md|settings([.]local)?[.]json)$\"))' >/dev/null 2>&1 && jq -n '{hookSpecificOutput:{hookEventName:\"PreToolUse\",permissionDecision:\"deny\",permissionDecisionReason:\"~/.claude/* are symlinks to the dotfiles repo. Edit the source at ~/dotfiles/claude/ instead (e.g. ~/dotfiles/claude/CLAUDE.md or ~/dotfiles/claude/settings.json).\"}}' || true" } ] } ] },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "cran.r-project.org",
        "cloud.r-project.org",
        "*.r-project.org",
        "github.com",
        "*.githubusercontent.com",
        "api.github.com",
        "cran.obiba.org",
        "localhost",
        "127.0.0.1",
        "registry-1.docker.io",
        "auth.docker.io",
        "*.docker.io",
        "production.cloudflare.docker.com",
        "repo.maven.apache.org",
        "repo1.maven.org",
        "obiba.jfrog.io",
        "*.jfrog.io",
        "plugins.gradle.org",
        "services.gradle.org",
        "repo.gradle.org",
        "jitpack.io",
        "registry.npmjs.org",
        "registry.molgenis.org",
        "armadillo-demo.molgenis.net"
      ],
      "allowLocalBinding": true,
      "allowUnixSockets": [
        "~/.docker/run/docker.sock"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "~/.gradle"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.config/gcloud",
        "~/.Renviron",
        "~/.netrc"
      ]
    },
    "excludedCommands": [
      "ps",
      "pgrep"
    ]
  }
}
